{
  "name": "@drawtonomy/sdk",
  "version": "0.4.0",
  "description": "SDK for building drawtonomy extensions",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
