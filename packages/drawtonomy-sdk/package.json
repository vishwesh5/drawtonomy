    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "keywords": [
    "drawtonomy",
    "extension",
    "sdk",
    "traffic",
    "drawing"
  ],
  "license": "Apache-2.0",
  "devDependencies": {
    "jsdom": "29.0.1",
    "typescript": "5.9.3",
    "vitest": "4.1.2"
  }
}
